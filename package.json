{
	"name": "@mirasen/chessboard",
	"description": "Framework-agnostic TypeScript chessboard platform with real chess interaction built in.",
	"version": "1.0.0",
	"license": "MIT",
	"author": {
		"name": "Mirasen",
		"email": "konstantin@mirasen.io"
	},
	"keywords": [
		"mirasen",
		"chessboard",
		"chess",
		"chess-ui",
		"chessboard-ui",
		"typescript",
		"framework-agnostic",
		"svg",
		"extensions",
		"chessboard-platform"
	],
	"homepage": "https://mirasen.io/chessboard",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/mirasen-io/chessboard.git"
	},
	"bugs": {
		"url": "https://github.com/mirasen-io/chessboard/issues"
	},
	"type": "module",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./extensions": {
			"types": "./dist/extensions/index.d.ts",
			"import": "./dist/extensions/index.js"
		},
		"./extensions/build": {
			"types": "./dist/extensions/build/index.d.ts",
			"import": "./dist/extensions/build/index.js"
		},
		"./unstable/*": {
			"types": "./dist/*.d.ts",
			"import": "./dist/*.js"
		}
	},
	"scripts": {
		"build": "rimraf ./dist && tsc --project tsconfig.json && npm run prepack",
		"build:release": "rimraf ./dist && tsc --project tsconfig-release.json && npm run prepack",
		"prepare": "bash ./scripts/npm-link.sh",
		"prepack": "publint",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"check": "tsc --skipLibCheck --noEmit",
		"check:test": "tsc --project tsconfig-test.json --skipLibCheck --noEmit",
		"test": "npm run check:test && vitest run --run",
		"coverage": "vitest run --coverage",
		"changeset:version": "changeset version && npm install && npm run format && git add --all",
		"changeset:publish": "changeset publish"
	},
	"files": [
		"dist",
		"assets",
		"README.md",
		"CHANGELOG.md",
		"LICENSE",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*",
		"!tests",
		"!examples",
		"!benchmarks"
	],
	"devDependencies": {
		"@changesets/cli": "^2.28.1",
		"@eslint/compat": "^2.0.2",
		"@eslint/js": "^10.0.1",
		"@types/node": "^25.5.0",
		"@vitest/coverage-istanbul": "^4.1.0",
		"eslint": "^10.0.2",
		"eslint-config-prettier": "^10.1.2",
		"globals": "^17.4.0",
		"jsdom": "^29.0.0",
		"prettier": "^3.5.3",
		"publint": "^0.3.11",
		"rimraf": "^6.0.1",
		"serve": "^14.2.6",
		"tsc-alias": "^1.8.15",
		"typescript": "^5.8.2",
		"typescript-eslint": "^8.57.0",
		"vitest": "^4.0.18"
	},
	"engines": {
		"node": ">=20"
	},
	"dependencies": {
		"@echecs/fen": "^2.1.0",
		"@ktarmyshov/assert": "^0.1.9",
		"es-toolkit": "^1.45.1",
		"type-fest": "^5.5.0"
	}
}
