{
	"name": "@ktarmyshov/chessboard",
	"description": "A chessboard UI library for JavaScript and TypeScript projects, providing an interactive and customizable chessboard component.",
	"version": "0.0.4",
	"license": "MIT",
	"author": {
		"name": "Konstantin Tarmyshov",
		"email": "k.tarmyshov@googlemail.com"
	},
	"keywords": [
		"chess",
		"chessboard",
		"chess-ui",
		"chess-component",
		"chess-library",
		"chessboard-ui",
		"chessboard-component",
		"chessboard-library"
	],
	"homepage": "https://github.com/kt-npm-modules/chessboard#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kt-npm-modules/chessboard.git"
	},
	"bugs": {
		"url": "https://github.com/kt-npm-modules/chessboard/issues"
	},
	"type": "module",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "rimraf ./dist && tsc --project tsconfig.json && npm run prepack",
		"build:release": "rimraf ./dist && tsc --project tsconfig-release.json && npm run prepack",
		"prepare": "bash ./scripts/npm-link.sh",
		"prepack": "publint",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"check": "tsc --skipLibCheck",
		"check:test": "tsc --project tsconfig-test.json --skipLibCheck",
		"test": "npm run check:test && vitest run",
		"coverage": "vitest run --coverage",
		"changeset:version": "changeset version && git add --all",
		"changeset:publish": "changeset publish"
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*",
		"!tests",
		"!examples",
		"!benchmarks"
	],
	"devDependencies": {
		"@changesets/cli": "^2.28.1",
		"@eslint/compat": "^2.0.2",
		"@eslint/js": "^10.0.1",
		"@types/node": "^25.5.0",
		"@vitest/coverage-istanbul": "^4.1.0",
		"eslint": "^10.0.2",
		"eslint-config-prettier": "^10.1.2",
		"globals": "^17.4.0",
		"prettier": "^3.5.3",
		"publint": "^0.3.11",
		"rimraf": "^6.0.1",
		"tsc-alias": "^1.8.15",
		"typescript": "^5.8.2",
		"typescript-eslint": "^8.57.1",
		"vitest": "^4.0.18"
	},
	"engines": {
		"node": ">=20"
	},
	"dependencies": {
		"@ktarmyshov/assert": "^0.1.9",
		"chess.js": "^1.4.0",
		"type-fest": "^5.5.0"
	}
}
